rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════════
// Single-player family — ONE Firestore (default) database shared by every game in
// the `singleplayer-mygames-live` project. Isolation between games is by COLLECTION
// PREFIX, enforced here (architecture §4.2). Each game gets its own top-level
// prefixed match block. A game's rules MUST NOT be written in terms that could
// match another game's future collections — so every match path below is literally
// prefixed with `pennies_`, never a wildcard segment that could span games.
//
// Defining family constraint (architecture §1): a student never reads another
// student's data. Enforced in rules, not just in the UI — see the participant
// block's uid check.
// ═══════════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Jar of Pennies (game_id: pennies) ──────────────────────────────────────

    // Instance document: students read (to render config-derived screen chrome);
    // never client-written (the instructor creates/configures it server-side).
    match /pennies_game_instances/{instanceId} {
      allow read: if request.auth != null;
      allow write: if false;

      // Per-instance instructor config (config/main). Student-readable — it holds
      // only non-secret settings (e.g. the jar image path). The TRUE VALUE is NOT
      // here; it lives in truth/ below (spec §4.4), so config/main is safe to read.
      match /config/{doc} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // TRUTH / answer key (truth/main → true_value). DENY ALL CLIENT ACCESS —
      // read AND write, unconditionally, forever, with NO exception for the
      // instructor (the instructor reads/writes it only through an authenticated
      // callable). eBay vCommon pattern (spec §4.4): the pedagogical value of the
      // game depends on this never leaking. Do not relax this rule, ever.
      match /truth/{doc} {
        allow read, write: if false;
      }
    }

    // Participant document (top-level, prefixed). A student may read ONLY their own
    // document — request.auth.uid IS the participant_id (minted as the Firebase UID
    // by penniesBootstrap). This one line is the family's defining constraint: no
    // student can read another student's estimate, bid, or outcome. No client
    // writes at all — every write goes through a callable (penniesSubmit, scoring).
    match /pennies_participants/{participantId} {
      allow read: if request.auth != null && request.auth.uid == participantId;
      allow write: if false;
    }

    // ── Poll (game_id: poll) ───────────────────────────────────────────────────

    // A poll has NO secret and NO truth document (Poll spec §8.3): the question
    // definitions ARE what the student answers, so config/main is client-readable.
    match /poll_game_instances/{instanceId} {
      allow read: if request.auth != null;
      allow write: if false;

      // The question list. Student-readable (they answer it); written only via
      // pollUpdateConfig. Deliberately NO truth/ subcollection — nothing is secret.
      match /config/{doc} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // Participant document (top-level, prefixed). A student may read ONLY their own —
    // request.auth.uid IS the participant_id. The family's defining constraint: no
    // student reads another student's answers. No client writes (callables only).
    match /poll_participants/{participantId} {
      allow read: if request.auth != null && request.auth.uid == participantId;
      allow write: if false;
    }
  }
}
