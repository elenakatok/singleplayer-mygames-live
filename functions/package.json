{
  "name": "singleplayer-functions",
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --only firestore --project demo-singleplayer --config ../firebase.json \"vitest run --config vitest.rules.config.ts\""
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@mygames/game-engine": "git+https://github.com/elenakatok/game-engine.git#v0.5.0",
    "@mygames/game-server": "git+https://github.com/elenakatok/game-server.git#v0.15.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0"
  }
}
